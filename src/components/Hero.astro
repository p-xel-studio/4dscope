---
import site from '@/content/site.json';
const { hero } = site;
---

<section id="hero-section" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-32 pb-24 px-8" aria-label="Présentation de la borne immersive Mira by 4D-Scope">

  <!-- Aurora CSS ribbons — GPU-accelerated, no canvas -->
  <div class="aurora-container absolute inset-0 overflow-hidden" aria-hidden="true">
    <!-- Left ribbon cluster -->
    <div class="aurora-ribbon ribbon-1"></div>
    <div class="aurora-ribbon ribbon-2"></div>
    <div class="aurora-ribbon ribbon-3"></div>
    <!-- Right ribbon cluster -->
    <div class="aurora-ribbon ribbon-4"></div>
    <div class="aurora-ribbon ribbon-5"></div>
    <!-- Accent ribbons -->
    <div class="aurora-ribbon ribbon-6"></div>
    <div class="aurora-ribbon ribbon-7"></div>
  </div>

  <!-- Dot grid canvas -->
  <canvas id="hero-dots" class="absolute inset-0 w-full h-full" style="mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black, transparent 70%); -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black, transparent 70%);"></canvas>

  <div class="relative z-10 text-center max-w-[920px]" style="pointer-events: none;">
    <!-- Badge -->
    <div class="gs-reveal inline-flex items-center gap-2 px-5 py-2 border border-accent-d rounded-full text-[0.78rem] tracking-wide text-accent mb-10">
      <span class="w-1.5 h-1.5 bg-accent rounded-full animate-pulse"></span>
      {hero.badge}
    </div>

    <!-- Title -->
    <h1 class="gs-reveal font-serif text-[clamp(3rem,7vw,5.5rem)] font-medium leading-[1.05] tracking-tight text-wh mb-6">
      {hero.title} <em class="italic text-accent">{hero.titleAccent}</em>
    </h1>

    <!-- Subtitle -->
    <p class="gs-reveal text-[1.15rem] leading-relaxed text-text-m max-w-[640px] mx-auto mb-5 font-light" set:html={hero.subtitle
      .replace('borne immersive VR', '<strong class="font-medium text-text">borne immersive VR</strong>')
      .replace('conçue pour le milieu public', '<strong class="font-medium text-text">conçue pour le milieu public</strong>')
    } />

    <!-- Keywords -->
    <p class="gs-reveal text-sm text-text-d mb-12">
      {hero.keywords.map((kw: string, i: number) => (
        <>{i > 0 && ' · '}<strong class="text-text-m font-normal">{kw}</strong></>
      ))}
    </p>

    <!-- CTAs -->
    <div class="gs-reveal flex gap-4 justify-center flex-wrap">
      <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg rounded-full text-[0.9rem] font-medium tracking-wide hover:bg-accent-l hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(90,170,150,0.2)] transition-all pointer-events-auto">
        {hero.cta}
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#cas-usage" class="inline-flex items-center gap-2 px-8 py-4 bg-transparent text-text border border-bdr-l rounded-full text-[0.9rem] font-medium tracking-wide hover:border-text-m hover:bg-white/[0.03] hover:-translate-y-0.5 transition-all pointer-events-auto">
        {hero.ctaSecondary}
      </a>
    </div>

    <!-- Device visual -->
    <div class="gs-reveal mt-20 relative">
      <div class="w-full max-w-[800px] mx-auto aspect-video bg-bg-el border border-bdr rounded-2xl overflow-hidden relative flex items-center justify-center">
        <div class="relative w-full h-full flex items-center justify-center bg-[radial-gradient(ellipse_60%_80%_at_50%_50%,rgba(90,170,150,0.12)_0%,transparent_70%)]">
          <div class="w-[120px] opacity-60">
            <svg viewBox="0 0 120 200" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="52" y="70" width="16" height="110" rx="8" fill="rgba(90,170,150,.15)" stroke="rgba(90,170,150,.3)" stroke-width="1"/>
              <ellipse cx="60" cy="70" rx="30" ry="20" fill="rgba(90,170,150,.1)" stroke="rgba(90,170,150,.25)" stroke-width="1"/>
              <rect x="38" y="50" width="44" height="30" rx="8" fill="rgba(90,170,150,.12)" stroke="rgba(90,170,150,.3)" stroke-width="1"/>
              <circle cx="50" cy="62" r="6" fill="none" stroke="rgba(90,170,150,.4)" stroke-width="1"/>
              <circle cx="70" cy="62" r="6" fill="none" stroke="rgba(90,170,150,.4)" stroke-width="1"/>
              <rect x="30" y="178" width="60" height="4" rx="2" fill="rgba(90,170,150,.2)"/>
            </svg>
          </div>
          <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[0.72rem] tracking-[0.15em] uppercase text-text-d">
            Mira V3 · Borne immersive VR par 4D-Scope
          </div>
        </div>

        <!-- Floating stats -->
        <div class="hidden lg:block absolute left-[-2rem] top-[30%] px-5 py-3 bg-bg-card/90 backdrop-blur-lg border border-bdr rounded-xl text-[0.78rem]">
          <span class="block font-serif text-[1.4rem] text-accent mb-0.5">350°</span>
          <span class="text-text-m">Rotation</span>
        </div>
        <div class="hidden lg:block absolute right-[-2rem] top-[50%] px-5 py-3 bg-bg-card/90 backdrop-blur-lg border border-bdr rounded-xl text-[0.78rem]">
          <span class="block font-serif text-[1.4rem] text-accent mb-0.5">5 ans</span>
          <span class="text-text-m">Garantie</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Aurora ribbon system — pure CSS, GPU-accelerated */
  .aurora-container {
    mix-blend-mode: screen;
  }

  .aurora-ribbon {
    position: absolute;
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    filter: blur(80px);
    will-change: transform;
    mix-blend-mode: screen;
  }

  /* === LEFT CLUSTER — sweeps from bottom-left === */

  /* Main left ribbon: wide, sweeping, dominant */
  .ribbon-1 {
    width: 120%;
    height: 45%;
    bottom: -10%;
    left: -40%;
    background: linear-gradient(
      135deg,
      rgba(30, 190, 160, 0.55) 0%,
      rgba(40, 150, 200, 0.4) 30%,
      rgba(50, 120, 185, 0.3) 60%,
      transparent 85%
    );
    border-radius: 20% 80% 60% 20% / 30% 60% 40% 50%;
    transform: rotate(-15deg) scaleX(1.3);
    animation: drift1 25s ease-in-out infinite alternate;
  }

  /* Secondary left: overlapping, offset */
  .ribbon-2 {
    width: 100%;
    height: 35%;
    bottom: -5%;
    left: -30%;
    background: linear-gradient(
      120deg,
      rgba(50, 210, 170, 0.45) 0%,
      rgba(60, 170, 210, 0.35) 35%,
      rgba(45, 130, 190, 0.2) 65%,
      transparent 90%
    );
    border-radius: 30% 70% 50% 40% / 50% 40% 60% 40%;
    transform: rotate(-8deg) scaleX(1.2);
    animation: drift2 30s ease-in-out infinite alternate;
  }

  /* Thin bright accent left */
  .ribbon-3 {
    width: 80%;
    height: 20%;
    bottom: 10%;
    left: -25%;
    background: linear-gradient(
      140deg,
      rgba(70, 230, 190, 0.5) 0%,
      rgba(80, 190, 220, 0.35) 40%,
      transparent 75%
    );
    border-radius: 60% 40% 50% 50% / 40% 60% 40% 60%;
    transform: rotate(-20deg) scaleX(1.5);
    animation: drift3 20s ease-in-out infinite alternate;
  }

  /* === RIGHT CLUSTER — sweeps from bottom-right === */

  /* Main right ribbon */
  .ribbon-4 {
    width: 110%;
    height: 40%;
    bottom: -8%;
    right: -40%;
    background: linear-gradient(
      225deg,
      rgba(40, 170, 200, 0.45) 0%,
      rgba(35, 140, 185, 0.35) 30%,
      rgba(30, 110, 170, 0.25) 60%,
      transparent 85%
    );
    border-radius: 60% 30% 40% 70% / 50% 40% 50% 40%;
    transform: rotate(12deg) scaleX(1.2);
    animation: drift4 28s ease-in-out infinite alternate;
  }

  /* Secondary right */
  .ribbon-5 {
    width: 90%;
    height: 30%;
    bottom: 0%;
    right: -30%;
    background: linear-gradient(
      210deg,
      rgba(55, 200, 190, 0.4) 0%,
      rgba(45, 160, 200, 0.3) 35%,
      rgba(35, 120, 180, 0.15) 70%,
      transparent 90%
    );
    border-radius: 50% 50% 30% 70% / 60% 30% 50% 40%;
    transform: rotate(18deg) scaleX(1.4);
    animation: drift5 22s ease-in-out infinite alternate;
  }

  /* === ACCENT RIBBONS — subtle connecting light === */

  /* Center-bottom glow connecting left and right */
  .ribbon-6 {
    width: 70%;
    height: 25%;
    bottom: -5%;
    left: 15%;
    background: radial-gradient(
      ellipse 100% 80% at 50% 80%,
      rgba(40, 190, 175, 0.3) 0%,
      rgba(50, 160, 200, 0.15) 50%,
      transparent 80%
    );
    border-radius: 50%;
    animation: drift6 35s ease-in-out infinite alternate;
  }

  /* Upper-left subtle whisp */
  .ribbon-7 {
    width: 60%;
    height: 15%;
    top: 15%;
    left: -20%;
    background: linear-gradient(
      130deg,
      rgba(40, 180, 165, 0.15) 0%,
      rgba(50, 150, 190, 0.08) 50%,
      transparent 80%
    );
    border-radius: 30% 70% 60% 40% / 50% 40% 60% 50%;
    transform: rotate(-10deg) scaleX(2);
    animation: drift7 40s ease-in-out infinite alternate;
  }

  /* === ANIMATIONS — slow, premium, gentle drift === */

  @keyframes drift1 {
    0%   { transform: rotate(-15deg) scaleX(1.3) translate(0, 0); }
    50%  { transform: rotate(-12deg) scaleX(1.35) translate(3%, -4%); }
    100% { transform: rotate(-18deg) scaleX(1.25) translate(-2%, 2%); }
  }

  @keyframes drift2 {
    0%   { transform: rotate(-8deg) scaleX(1.2) translate(0, 0); }
    50%  { transform: rotate(-5deg) scaleX(1.25) translate(4%, -3%); }
    100% { transform: rotate(-11deg) scaleX(1.15) translate(-1%, 3%); }
  }

  @keyframes drift3 {
    0%   { transform: rotate(-20deg) scaleX(1.5) translate(0, 0); }
    50%  { transform: rotate(-16deg) scaleX(1.6) translate(5%, -5%); }
    100% { transform: rotate(-24deg) scaleX(1.4) translate(-3%, 2%); }
  }

  @keyframes drift4 {
    0%   { transform: rotate(12deg) scaleX(1.2) translate(0, 0); }
    50%  { transform: rotate(15deg) scaleX(1.25) translate(-3%, -3%); }
    100% { transform: rotate(9deg) scaleX(1.15) translate(2%, 2%); }
  }

  @keyframes drift5 {
    0%   { transform: rotate(18deg) scaleX(1.4) translate(0, 0); }
    50%  { transform: rotate(14deg) scaleX(1.5) translate(-4%, -4%); }
    100% { transform: rotate(22deg) scaleX(1.3) translate(2%, 3%); }
  }

  @keyframes drift6 {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.8; }
    50%  { transform: translate(3%, -2%) scale(1.05); opacity: 1; }
    100% { transform: translate(-2%, 1%) scale(0.95); opacity: 0.7; }
  }

  @keyframes drift7 {
    0%   { transform: rotate(-10deg) scaleX(2) translate(0, 0); opacity: 0.7; }
    50%  { transform: rotate(-7deg) scaleX(2.1) translate(5%, 3%); opacity: 1; }
    100% { transform: rotate(-13deg) scaleX(1.9) translate(-3%, -2%); opacity: 0.6; }
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .aurora-ribbon {
      animation: none !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const dotsCanvas = document.getElementById('hero-dots') as HTMLCanvasElement;
  const section = document.getElementById('hero-section');

  if (dotsCanvas && section) {
    const ctx = dotsCanvas.getContext('2d')!;
    let width = 0;
    let height = 0;
    let cols = 0;
    let rows = 0;
    let spacing = 22;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    if (isMobile) spacing = 38;

    const baseRadius = isMobile ? 0.8 : 1;
    const accentR = 90, accentG = 170, accentB = 150;

    // Mouse interaction
    const mouse = { x: -9999, y: -9999 };
    const mouseSmooth = { x: -9999, y: -9999 };
    const mouseRadius = isMobile ? 0 : 160;

    if (!isMobile) {
      section.addEventListener('mousemove', (e) => {
        const rect = dotsCanvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });
      section.addEventListener('mouseleave', () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = dotsCanvas.offsetWidth;
      height = dotsCanvas.offsetHeight;
      dotsCanvas.width = width * dpr;
      dotsCanvas.height = height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(width / spacing) + 1;
      rows = Math.ceil(height / spacing) + 1;
    }

    resize();
    window.addEventListener('resize', resize);

    const state = { time: 0 };

    function draw() {
      ctx.clearRect(0, 0, width, height);
      const t = state.time;

      mouseSmooth.x += (mouse.x - mouseSmooth.x) * 0.12;
      mouseSmooth.y += (mouse.y - mouseSmooth.y) * 0.12;
      const mx = mouseSmooth.x;
      const my = mouseSmooth.y;
      const mr2 = mouseRadius * mouseRadius;

      for (let row = 0; row < rows; row++) {
        const y = row * spacing;
        for (let col = 0; col < cols; col++) {
          const x = col * spacing;

          const wave1 = Math.sin(x * 0.008 + t * 1.2) * Math.cos(y * 0.006 + t * 0.8);
          const wave2 = Math.sin((x + y) * 0.005 + t * 0.6) * 0.5;
          const combined = (wave1 + wave2) * 0.5 + 0.5;

          let opacity = 0.05 + combined * 0.3;
          let radius = baseRadius + combined * 0.6;

          // Mouse proximity
          const dx = x - mx;
          const dy = y - my;
          const dist2 = dx * dx + dy * dy;
          if (dist2 < mr2) {
            const proximity = 1 - Math.sqrt(dist2) / mouseRadius;
            const ease = proximity * proximity * proximity;
            opacity += ease * 0.6;
            radius += ease * 3.5;
          }

          ctx.beginPath();
          ctx.arc(x, y, radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${accentR},${accentG},${accentB},${opacity})`;
          ctx.fill();
        }
      }
    }

    gsap.ticker.add(draw);
    gsap.to(state, { time: 100, duration: 100, ease: 'none', repeat: -1 });

    document.addEventListener('astro:before-swap', () => {
      gsap.ticker.remove(draw);
      window.removeEventListener('resize', resize);
    });
  }
</script>
