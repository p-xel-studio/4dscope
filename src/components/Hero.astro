---
import site from '@/content/site.json';
const { hero } = site;
---

<section id="hero-section" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-32 pb-24 px-8" aria-label="Présentation de la borne immersive Mira by 4D-Scope">

  <!-- Video background -->
  <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline aria-hidden="true">
    <source src="/Animated_background.webm" type="video/webm" />
  </video>
  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-black/65"></div>

  <!-- Dot grid canvas -->
  <canvas id="hero-dots" class="absolute inset-0 w-full h-full" style="mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black, transparent 70%); -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black, transparent 70%);"></canvas>

  <div class="relative z-10 text-center max-w-[920px]" style="pointer-events: none;">
    <!-- Badge -->
    <div class="gs-reveal inline-flex items-center gap-2 px-5 py-2 border border-accent-d rounded-full text-[0.78rem] tracking-wide text-accent mb-10">
      <span class="w-1.5 h-1.5 bg-accent rounded-full animate-pulse"></span>
      {hero.badge}
    </div>

    <!-- Title -->
    <h1 class="gs-reveal font-serif text-[clamp(3rem,7vw,5.5rem)] font-medium leading-[1.05] tracking-tight text-wh mb-6">
      {hero.title} <em class="italic text-accent">{hero.titleAccent}</em>
    </h1>

    <!-- Subtitle -->
    <p class="gs-reveal text-[1.15rem] leading-relaxed text-text-m max-w-[640px] mx-auto mb-5 font-light" set:html={hero.subtitle
      .replace('borne immersive VR', '<strong class="font-medium text-text">borne immersive VR</strong>')
      .replace('conçue pour le milieu public', '<strong class="font-medium text-text">conçue pour le milieu public</strong>')
    } />

    <!-- Keywords -->
    <p class="gs-reveal text-sm text-text-d mb-12">
      {hero.keywords.map((kw: string, i: number) => (
        <>{i > 0 && ' · '}<strong class="text-text-m font-normal">{kw}</strong></>
      ))}
    </p>

    <!-- CTAs -->
    <div class="gs-reveal flex gap-4 justify-center flex-wrap">
      <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg rounded-full text-[0.9rem] font-medium tracking-wide whitespace-nowrap hover:bg-accent-l hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(90,170,150,0.2)] transition-all pointer-events-auto">
        {hero.cta}
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#cas-usage" class="inline-flex items-center gap-2 px-8 py-4 bg-transparent text-text border border-bdr-l rounded-full text-[0.9rem] font-medium tracking-wide hover:border-text-m hover:bg-white/[0.03] hover:-translate-y-0.5 transition-all pointer-events-auto">
        {hero.ctaSecondary}
      </a>
    </div>

    <!-- Product visual + floating cards -->
    <div class="mt-16 relative max-w-[900px] mx-auto pointer-events-auto mb-[-8rem]">
      <!-- Mira product image -->
      <div class="gs-reveal relative flex justify-center items-end">
        <img src="/Mira_borne.webp" alt="Mira V3 by 4D-Scope, borne immersive VR" class="w-[380px] sm:w-[480px] lg:w-[580px] drop-shadow-[0_20px_60px_rgba(90,170,150,0.15)]" width="800" height="900" loading="eager" />
      </div>

      <!-- Floating spec cards -->
      <div class="hero-card absolute left-0 lg:left-[-3rem] top-[8%] px-5 py-4 bg-white/[0.05] backdrop-blur-xl border border-white/[0.08] rounded-2xl max-w-[230px]">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="w-8 h-8 rounded-lg bg-accent/15 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <span class="text-[0.88rem] font-medium text-text">350° de rotation</span>
        </div>
        <p class="text-[0.78rem] text-text-m leading-relaxed">Rotation horizontale fluide, inclinaison verticale de -45° à +45°</p>
      </div>

      <div class="hero-card absolute right-0 lg:right-[-3rem] top-[5%] px-5 py-4 bg-white/[0.05] backdrop-blur-xl border border-white/[0.08] rounded-2xl max-w-[230px]">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="w-8 h-8 rounded-lg bg-accent/15 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span class="text-[0.88rem] font-medium text-text">Anti-vandalisme</span>
        </div>
        <p class="text-[0.78rem] text-text-m leading-relaxed">Acier inoxydable, aluminium et polyamide renforcé carbone</p>
      </div>

      <div class="hero-card absolute left-[5%] lg:left-0 bottom-[15%] px-5 py-4 bg-white/[0.05] backdrop-blur-xl border border-white/[0.08] rounded-2xl max-w-[230px]">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="w-8 h-8 rounded-lg bg-accent/15 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          </div>
          <span class="text-[0.88rem] font-medium text-text">100% autonome</span>
        </div>
        <p class="text-[0.78rem] text-text-m leading-relaxed">Alimentation autonome avec batterie de secours, aucun personnel requis</p>
      </div>

      <div class="hero-card absolute right-[5%] lg:right-0 bottom-[20%] px-5 py-4 bg-white/[0.05] backdrop-blur-xl border border-white/[0.08] rounded-2xl max-w-[230px]">
        <div class="flex items-center gap-2.5 mb-2">
          <div class="w-8 h-8 rounded-lg bg-accent/15 flex items-center justify-center">
            <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
          </div>
          <span class="text-[0.88rem] font-medium text-text">Fabrication belge</span>
        </div>
        <p class="text-[0.78rem] text-text-m leading-relaxed">Conçue, fabriquée et assemblée en Belgique, garantie 5 ans</p>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const dotsCanvas = document.getElementById('hero-dots') as HTMLCanvasElement;
  const section = document.getElementById('hero-section');

  if (dotsCanvas && section) {
    const ctx = dotsCanvas.getContext('2d')!;
    let width = 0;
    let height = 0;
    let cols = 0;
    let rows = 0;
    let spacing = 22;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    if (isMobile) spacing = 38;

    const baseRadius = isMobile ? 0.8 : 1;
    const accentR = 90, accentG = 170, accentB = 150;

    // Mouse interaction
    const mouse = { x: -9999, y: -9999 };
    const mouseSmooth = { x: -9999, y: -9999 };
    const mouseRadius = isMobile ? 0 : 160;

    if (!isMobile) {
      section.addEventListener('mousemove', (e) => {
        const rect = dotsCanvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });
      section.addEventListener('mouseleave', () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      width = dotsCanvas.offsetWidth;
      height = dotsCanvas.offsetHeight;
      dotsCanvas.width = width * dpr;
      dotsCanvas.height = height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(width / spacing) + 1;
      rows = Math.ceil(height / spacing) + 1;
    }

    resize();
    window.addEventListener('resize', resize);

    const state = { time: 0 };

    function draw() {
      ctx.clearRect(0, 0, width, height);
      const t = state.time;

      mouseSmooth.x += (mouse.x - mouseSmooth.x) * 0.12;
      mouseSmooth.y += (mouse.y - mouseSmooth.y) * 0.12;
      const mx = mouseSmooth.x;
      const my = mouseSmooth.y;
      const mr2 = mouseRadius * mouseRadius;

      for (let row = 0; row < rows; row++) {
        const y = row * spacing;
        for (let col = 0; col < cols; col++) {
          const x = col * spacing;

          const wave1 = Math.sin(x * 0.008 + t * 1.2) * Math.cos(y * 0.006 + t * 0.8);
          const wave2 = Math.sin((x + y) * 0.005 + t * 0.6) * 0.5;
          const combined = (wave1 + wave2) * 0.5 + 0.5;

          let opacity = 0.05 + combined * 0.3;
          let radius = baseRadius + combined * 0.6;

          const dx = x - mx;
          const dy = y - my;
          const dist2 = dx * dx + dy * dy;
          if (dist2 < mr2) {
            const proximity = 1 - Math.sqrt(dist2) / mouseRadius;
            const ease = proximity * proximity * proximity;
            opacity += ease * 0.85;
            radius += ease * 4;
          }

          ctx.beginPath();
          ctx.arc(x, y, radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${accentR},${accentG},${accentB},${opacity})`;
          ctx.fill();
        }
      }
    }

    gsap.ticker.add(draw);
    gsap.to(state, { time: 100, duration: 100, ease: 'none', repeat: -1 });

    document.addEventListener('astro:before-swap', () => {
      gsap.ticker.remove(draw);
      window.removeEventListener('resize', resize);
    });
  }

  // Floating cards stagger animation
  const heroCards = document.querySelectorAll('.hero-card');
  if (heroCards.length) {
    gsap.set(heroCards, { opacity: 0, y: 30, scale: 0.95 });
    gsap.to(heroCards, {
      opacity: 1,
      y: 0,
      scale: 1,
      duration: 0.8,
      ease: 'power3.out',
      stagger: 0.15,
      delay: 0.8,
      scrollTrigger: {
        trigger: heroCards[0].parentElement,
        start: 'top 80%',
        once: true,
      },
    });

    // Subtle floating animation after entrance
    heroCards.forEach((card, i) => {
      gsap.to(card, {
        y: -6,
        duration: 2.5 + i * 0.3,
        ease: 'sine.inOut',
        repeat: -1,
        yoyo: true,
        delay: 1.5 + i * 0.15,
        force3d: true,
        rotation: 0.01,
      });
    });
  }
</script>
