---
import site from '@/content/site.json';
const { differentiator } = site;
---

<section class="py-32 bg-bg" id="pourquoi">
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="gs-reveal">
      <div class="inline-flex items-center gap-2.5 text-[0.72rem] tracking-[0.18em] uppercase text-accent mb-6 before:content-[''] before:w-6 before:h-px before:bg-accent">{differentiator.tag}</div>
      <h2 class="font-serif text-[clamp(2rem,4vw,3.2rem)] font-medium leading-tight text-wh mb-4">{differentiator.title}</h2>
      <p class="text-[1.05rem] text-text-m max-w-[560px] leading-relaxed font-light">{differentiator.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start mt-16">
      <!-- Points -->
      <div class="gs-reveal flex flex-col gap-7">
        {differentiator.points.map((point: { title: string; text: string }) => (
          <div class="flex gap-5 items-start">
            <div class="flex-shrink-0 w-10 h-10 rounded-[10px] bg-accent/10 border border-accent/15 flex items-center justify-center text-accent">
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" />
                <path d="M9 12l2 2 4-4" />
              </svg>
            </div>
            <div>
              <h4 class="text-base text-wh mb-1 font-medium">{point.title}</h4>
              <p class="text-[0.88rem] text-text-m leading-relaxed">{point.text}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Comparison table -->
      <div class="gs-reveal bg-bg-card border border-bdr rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3 border-b-2 border-accent/20">
          <div class="px-5 py-5 text-[0.75rem] tracking-[0.1em] uppercase text-text font-bold text-left">Caractéristique</div>
          <div class="px-5 py-5 text-[0.75rem] tracking-[0.1em] uppercase text-accent font-bold text-center bg-accent/[0.06]">4D-Scope Mira</div>
          <div class="px-5 py-5 text-[0.75rem] tracking-[0.1em] uppercase text-text-d font-bold text-center">Alternatives</div>
        </div>
        {differentiator.comparison.map((row: { feature: string; us: string; them: string }) => (
          <div class="grid grid-cols-3 border-b border-bdr last:border-b-0 hover:bg-white/[0.02] transition-colors">
            <div class="px-5 py-4 text-[0.85rem] text-text font-medium text-left">{row.feature}</div>
            <div class="px-5 py-4 text-[0.85rem] text-accent font-semibold text-center bg-accent/[0.06]">{row.us}</div>
            <div class="px-5 py-4 text-[0.85rem] text-text-d text-center">{row.them}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
