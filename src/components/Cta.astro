---
import site from '@/content/site.json';
const { cta } = site;
---

<section class="relative py-40 text-center overflow-hidden" id="contact">
  <!-- Animated flowing ribbons -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <!-- Large ribbon from bottom-left sweeping up-right -->
    <div class="cta-ribbon ribbon-1"></div>
    <div class="cta-ribbon ribbon-2"></div>
    <div class="cta-ribbon ribbon-3"></div>
    <!-- Ambient glow beneath ribbons -->
    <div class="cta-glow glow-left"></div>
    <div class="cta-glow glow-right"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-8">
    <div class="gs-reveal">
      <div class="inline-flex items-center gap-2.5 text-[0.72rem] tracking-[0.18em] uppercase text-accent mb-6 before:content-[''] before:w-6 before:h-px before:bg-accent">{cta.tag}</div>
      <h2 class="font-serif text-[clamp(2.5rem,5vw,4rem)] font-medium leading-tight text-wh max-w-[700px] mx-auto mb-4">
        {cta.title} <em class="italic text-accent font-serif">{cta.titleAccent}</em>
      </h2>
      <p class="text-[1.05rem] text-text-m max-w-[520px] mx-auto leading-relaxed font-light mb-12">{cta.subtitle}</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href={`mailto:${cta.email}`} class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg rounded-full text-[0.9rem] font-medium tracking-wide hover:bg-accent-l hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(90,170,150,0.2)] transition-all">
          {cta.primary}
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#" class="inline-flex items-center gap-2 px-8 py-4 bg-transparent text-text border border-bdr-l rounded-full text-[0.9rem] font-medium tracking-wide hover:border-text-m hover:bg-white/[0.03] hover:-translate-y-0.5 transition-all">
          {cta.secondary}
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M8 2v9m0 0l-3-3m3 3l3-3M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Elongated ribbon shapes — NOT circles */
  .cta-ribbon {
    position: absolute;
    will-change: transform;
    pointer-events: none;
  }

  /* Ribbon 1 — large, sweeps from bottom-left to upper-right */
  .ribbon-1 {
    width: 120%;
    height: 180px;
    left: -20%;
    bottom: 15%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(60, 200, 160, 0.25) 20%,
      rgba(90, 170, 150, 0.4) 45%,
      rgba(70, 190, 175, 0.35) 55%,
      rgba(80, 180, 190, 0.2) 80%,
      transparent 100%
    );
    filter: blur(40px);
    border-radius: 40% 60% 50% 50%;
    transform-origin: center center;
    animation: ribbonSweep1 16s ease-in-out infinite alternate;
  }

  /* Ribbon 2 — thinner, crosses ribbon 1 at an angle */
  .ribbon-2 {
    width: 110%;
    height: 100px;
    left: -10%;
    bottom: 30%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(80, 190, 180, 0.15) 25%,
      rgba(60, 210, 165, 0.35) 50%,
      rgba(90, 170, 150, 0.2) 75%,
      transparent 100%
    );
    filter: blur(30px);
    border-radius: 50%;
    transform-origin: 30% 50%;
    animation: ribbonSweep2 20s ease-in-out infinite alternate;
  }

  /* Ribbon 3 — subtle accent, sharper */
  .ribbon-3 {
    width: 100%;
    height: 60px;
    left: 0;
    top: 60%;
    background: linear-gradient(
      90deg,
      transparent 5%,
      rgba(116, 196, 174, 0.15) 30%,
      rgba(90, 170, 150, 0.5) 50%,
      rgba(116, 196, 174, 0.15) 70%,
      transparent 95%
    );
    filter: blur(15px);
    border-radius: 50%;
    animation: ribbonSweep3 12s ease-in-out infinite alternate;
  }

  /* Ambient glow blobs — large and very soft */
  .cta-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }

  .glow-left {
    width: 500px;
    height: 500px;
    left: -5%;
    bottom: -10%;
    background: radial-gradient(circle, rgba(60, 200, 160, 0.15) 0%, transparent 70%);
    filter: blur(60px);
    animation: glowPulse1 14s ease-in-out infinite alternate;
  }

  .glow-right {
    width: 450px;
    height: 450px;
    right: -5%;
    top: -10%;
    background: radial-gradient(circle, rgba(80, 180, 190, 0.12) 0%, transparent 70%);
    filter: blur(60px);
    animation: glowPulse2 18s ease-in-out infinite alternate;
  }

  /* Ribbon animations — large sweeping transforms */
  @keyframes ribbonSweep1 {
    0%   { transform: translateX(-5%) translateY(20px) rotate(-3deg) scaleY(1); }
    50%  { transform: translateX(3%) translateY(-30px) rotate(2deg) scaleY(1.4); }
    100% { transform: translateX(8%) translateY(10px) rotate(-1deg) scaleY(0.8); }
  }

  @keyframes ribbonSweep2 {
    0%   { transform: translateX(5%) translateY(0) rotate(2deg) scaleY(1); }
    50%  { transform: translateX(-8%) translateY(-20px) rotate(-3deg) scaleY(1.5); }
    100% { transform: translateX(3%) translateY(15px) rotate(1deg) scaleY(0.9); }
  }

  @keyframes ribbonSweep3 {
    0%   { transform: translateX(-3%) scaleX(0.85) scaleY(1); opacity: 0.6; }
    50%  { transform: translateX(5%) scaleX(1.1) scaleY(2); opacity: 1; }
    100% { transform: translateX(-3%) scaleX(0.85) scaleY(1); opacity: 0.6; }
  }

  @keyframes glowPulse1 {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.7; }
    100% { transform: translate(8%, -10%) scale(1.2); opacity: 1; }
  }

  @keyframes glowPulse2 {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.6; }
    100% { transform: translate(-6%, 8%) scale(1.15); opacity: 0.9; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-ribbon, .cta-glow { animation: none !important; }
  }
</style>
