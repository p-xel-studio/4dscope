---
import site from '@/content/site.json';
const { cta } = site;
---

<section class="relative py-40 text-center overflow-hidden" id="contact">
  <!-- Animated light ribbon background -->
  <div class="absolute inset-0" aria-hidden="true">
    <!-- Main flowing ribbon -->
    <div class="cta-ribbon ribbon-main"></div>
    <!-- Secondary ribbon, offset -->
    <div class="cta-ribbon ribbon-secondary"></div>
    <!-- Thin bright accent -->
    <div class="cta-ribbon ribbon-accent"></div>
    <!-- Soft ambient glow -->
    <div class="cta-ribbon ribbon-ambient"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-8">
    <div class="gs-reveal">
      <div class="inline-flex items-center gap-2.5 text-[0.72rem] tracking-[0.18em] uppercase text-accent mb-6 before:content-[''] before:w-6 before:h-px before:bg-accent">{cta.tag}</div>
      <h2 class="font-serif text-[clamp(2.5rem,5vw,4rem)] font-medium leading-tight text-wh max-w-[700px] mx-auto mb-4">
        {cta.title} <em class="italic text-accent font-serif">{cta.titleAccent}</em>
      </h2>
      <p class="text-[1.05rem] text-text-m max-w-[520px] mx-auto leading-relaxed font-light mb-12">{cta.subtitle}</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href={`mailto:${cta.email}`} class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg rounded-full text-[0.9rem] font-medium tracking-wide hover:bg-accent-l hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(90,170,150,0.2)] transition-all">
          {cta.primary}
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#" class="inline-flex items-center gap-2 px-8 py-4 bg-transparent text-text border border-bdr-l rounded-full text-[0.9rem] font-medium tracking-wide hover:border-text-m hover:bg-white/[0.03] hover:-translate-y-0.5 transition-all">
          {cta.secondary}
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M8 2v9m0 0l-3-3m3 3l3-3M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-ribbon {
    position: absolute;
    will-change: transform;
    pointer-events: none;
  }

  /* Main ribbon — wide flowing band across the section */
  .ribbon-main {
    width: 140%;
    height: 120px;
    left: -20%;
    top: 55%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(70, 185, 155, 0.06) 15%,
      rgba(90, 170, 150, 0.14) 35%,
      rgba(60, 190, 165, 0.18) 50%,
      rgba(90, 170, 150, 0.14) 65%,
      rgba(70, 185, 155, 0.06) 85%,
      transparent 100%
    );
    filter: blur(40px);
    border-radius: 50%;
    animation: ribbonFlow 20s ease-in-out infinite;
  }

  /* Secondary — overlapping, slightly different position */
  .ribbon-secondary {
    width: 130%;
    height: 90px;
    left: -15%;
    top: 40%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(80, 175, 190, 0.04) 20%,
      rgba(70, 190, 175, 0.12) 40%,
      rgba(50, 200, 160, 0.15) 55%,
      rgba(70, 190, 175, 0.10) 70%,
      rgba(80, 175, 190, 0.04) 85%,
      transparent 100%
    );
    filter: blur(50px);
    border-radius: 50%;
    animation: ribbonFlow2 25s ease-in-out infinite;
  }

  /* Thin bright accent — sharper, more defined */
  .ribbon-accent {
    width: 120%;
    height: 40px;
    left: -10%;
    top: 50%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(90, 170, 150, 0.03) 25%,
      rgba(90, 170, 150, 0.20) 45%,
      rgba(116, 196, 174, 0.25) 50%,
      rgba(90, 170, 150, 0.20) 55%,
      rgba(90, 170, 150, 0.03) 75%,
      transparent 100%
    );
    filter: blur(20px);
    border-radius: 50%;
    animation: ribbonFlow3 16s ease-in-out infinite;
  }

  /* Ambient glow — large, very soft */
  .ribbon-ambient {
    width: 80%;
    height: 300px;
    left: 10%;
    top: 25%;
    background: radial-gradient(
      ellipse 100% 100% at 50% 50%,
      rgba(90, 170, 150, 0.06) 0%,
      rgba(60, 190, 165, 0.03) 40%,
      transparent 70%
    );
    filter: blur(60px);
    animation: ambientBreathe 12s ease-in-out infinite;
  }

  @keyframes ribbonFlow {
    0%   { transform: translateX(-3%) scaleY(1) rotate(-1deg); }
    25%  { transform: translateX(2%) scaleY(1.3) rotate(0.5deg); }
    50%  { transform: translateX(4%) scaleY(0.8) rotate(1deg); }
    75%  { transform: translateX(1%) scaleY(1.2) rotate(-0.5deg); }
    100% { transform: translateX(-3%) scaleY(1) rotate(-1deg); }
  }

  @keyframes ribbonFlow2 {
    0%   { transform: translateX(4%) scaleY(1) rotate(0.5deg); }
    25%  { transform: translateX(-2%) scaleY(1.4) rotate(-0.5deg); }
    50%  { transform: translateX(-5%) scaleY(0.7) rotate(-1deg); }
    75%  { transform: translateX(1%) scaleY(1.1) rotate(0.3deg); }
    100% { transform: translateX(4%) scaleY(1) rotate(0.5deg); }
  }

  @keyframes ribbonFlow3 {
    0%   { transform: translateX(-2%) scaleX(1) scaleY(1); opacity: 0.8; }
    33%  { transform: translateX(3%) scaleX(1.1) scaleY(1.5); opacity: 1; }
    66%  { transform: translateX(5%) scaleX(0.95) scaleY(0.8); opacity: 0.9; }
    100% { transform: translateX(-2%) scaleX(1) scaleY(1); opacity: 0.8; }
  }

  @keyframes ambientBreathe {
    0%   { transform: scale(1); opacity: 0.7; }
    50%  { transform: scale(1.15); opacity: 1; }
    100% { transform: scale(1); opacity: 0.7; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-ribbon { animation: none !important; }
  }
</style>
