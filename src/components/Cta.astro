---
import site from '@/content/site.json';
const { cta } = site;
---

<section class="relative py-40 text-center overflow-hidden" id="contact">
  <!-- Animated glow orbs -->
  <div class="absolute inset-0" aria-hidden="true">
    <div class="cta-orb cta-orb-1"></div>
    <div class="cta-orb cta-orb-2"></div>
    <div class="cta-orb cta-orb-3"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-8">
    <div class="gs-reveal">
      <div class="inline-flex items-center gap-2.5 text-[0.72rem] tracking-[0.18em] uppercase text-accent mb-6 before:content-[''] before:w-6 before:h-px before:bg-accent">{cta.tag}</div>
      <h2 class="font-serif text-[clamp(2.5rem,5vw,4rem)] font-medium leading-tight text-wh max-w-[700px] mx-auto mb-4">
        {cta.title} <em class="italic text-accent font-serif">{cta.titleAccent}</em>
      </h2>
      <p class="text-[1.05rem] text-text-m max-w-[520px] mx-auto leading-relaxed font-light mb-12">{cta.subtitle}</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href={`mailto:${cta.email}`} class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-bg rounded-full text-[0.9rem] font-medium tracking-wide hover:bg-accent-l hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(90,170,150,0.2)] transition-all">
          {cta.primary}
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#" class="inline-flex items-center gap-2 px-8 py-4 bg-transparent text-text border border-bdr-l rounded-full text-[0.9rem] font-medium tracking-wide hover:border-text-m hover:bg-white/[0.03] hover:-translate-y-0.5 transition-all">
          {cta.secondary}
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M8 2v9m0 0l-3-3m3 3l3-3M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    mix-blend-mode: screen;
    will-change: transform;
  }

  .cta-orb-1 {
    width: 500px;
    height: 500px;
    left: 10%;
    top: -20%;
    background: radial-gradient(circle, rgba(50, 200, 160, 0.18) 0%, transparent 70%);
    animation: ctaFloat1 18s ease-in-out infinite alternate;
  }

  .cta-orb-2 {
    width: 400px;
    height: 400px;
    right: 5%;
    bottom: -15%;
    background: radial-gradient(circle, rgba(70, 170, 200, 0.15) 0%, transparent 70%);
    animation: ctaFloat2 22s ease-in-out infinite alternate;
  }

  .cta-orb-3 {
    width: 350px;
    height: 350px;
    left: 40%;
    bottom: -10%;
    background: radial-gradient(circle, rgba(40, 210, 150, 0.12) 0%, transparent 70%);
    animation: ctaFloat3 15s ease-in-out infinite alternate;
  }

  @keyframes ctaFloat1 {
    0%   { transform: translate(0, 0) scale(1); }
    50%  { transform: translate(5%, 10%) scale(1.1); }
    100% { transform: translate(-3%, 5%) scale(0.95); }
  }

  @keyframes ctaFloat2 {
    0%   { transform: translate(0, 0) scale(1); }
    50%  { transform: translate(-6%, -8%) scale(1.15); }
    100% { transform: translate(4%, -3%) scale(0.9); }
  }

  @keyframes ctaFloat3 {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.8; }
    50%  { transform: translate(-4%, 6%) scale(1.1); opacity: 1; }
    100% { transform: translate(6%, -4%) scale(0.95); opacity: 0.7; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-orb { animation: none !important; }
  }
</style>
