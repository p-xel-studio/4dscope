---
import site from '@/content/site.json';
const { trust } = site;

const logos = [
  { src: '/Archeoforum_Logo.webp', alt: 'Archéoforum de Liège', name: 'Archéoforum', location: 'Liège', bright: true },
  { src: '/logo-Curtius.webp', alt: 'Grand Curtius', name: 'Grand Curtius', location: 'Liège', bright: false },
  { src: '/Logo_porte-hal.svg', alt: 'Porte de Hal', name: 'Porte de Hal', location: 'Bruxelles', bright: false },
  { src: '/Louvre-len-vallee.webp', alt: 'Louvre Lens Vallée', name: 'Louvre Lens Vallée', location: 'France', bright: true },
  { src: '/logo-terra-mosana.webp', alt: 'Terra Mosana', name: 'Terra Mosana', location: 'Eurorégion', bright: false },
  { src: '/University_of_Liege_logo.svg', alt: 'Université de Liège', name: 'ULiège', location: 'Liège', bright: false },
  { src: '/liege.webp', alt: 'Ville de Liège', name: 'Ville de Liège', location: 'Liège', bright: 'extra' },
  { src: '/tresor.webp', alt: 'Trésor de Liège', name: 'Trésor de Liège', location: 'Liège', bright: true },
  { src: '/Logo_DODS.webp', alt: 'D.O. Design Studio', name: 'D.O. Design Studio', location: 'Belgique', bright: false },
  { src: '/P-XEL-STUDIO_LOGO.webp', alt: 'P-XEL Studio', name: 'P-XEL Studio', location: 'Liège', bright: true },
];
---

<section class="py-12 sm:py-16 border-t border-b border-bdr" aria-label="Sites de référence">
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="grid grid-cols-2 sm:grid-cols-5 lg:grid-cols-10 gap-x-6 gap-y-8 lg:gap-8">
      {logos.map((logo) => (
        <div class="flex flex-col items-center gap-2.5 group">
          <img
            src={logo.src}
            alt={logo.alt}
            width="80"
            height="36"
            loading="lazy"
            class:list={[
              'h-9 lg:h-10 object-contain transition-all duration-300 grayscale group-hover:grayscale-0',
              logo.bright === 'extra' ? 'opacity-90 brightness-200 group-hover:opacity-100 group-hover:brightness-100' : logo.bright ? 'opacity-80 brightness-150 group-hover:opacity-100 group-hover:brightness-100' : 'opacity-60 group-hover:opacity-100'
            ]}
          />
          <div class="text-center">
            <div class="text-[0.72rem] text-text-m font-medium">{logo.name}</div>
            <div class="text-[0.62rem] text-text-d">{logo.location}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
