---
import installations from '@/content/installations.json';
---

<section class="py-32 bg-bg" id="installations">
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="gs-reveal">
      <div class="inline-flex items-center gap-2.5 text-[0.72rem] tracking-[0.18em] uppercase text-accent mb-6 before:content-[''] before:w-6 before:h-px before:bg-accent">{installations.tag}</div>
      <h2 class="font-serif text-[clamp(2rem,4vw,3.2rem)] font-medium leading-tight text-wh mb-4">{installations.title}</h2>
      <p class="text-[1.05rem] text-text-m max-w-[560px] leading-relaxed font-light">{installations.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-16">
      {installations.items.map((inst: { icon: string; title: string; location: string; text: string; gradient: string[] }) => (
        <article class="gs-reveal border border-bdr rounded-2xl overflow-hidden bg-bg-card transition-all duration-400 hover:border-accent-d hover:-translate-y-1">
          <div
            class="aspect-[3/2] flex items-center justify-center text-[2.5rem]"
            style={`background: linear-gradient(135deg, ${inst.gradient[0]}, ${inst.gradient[1]})`}
          >
            {inst.icon}
          </div>
          <div class="p-6">
            <h3 class="font-serif text-[1.15rem] text-wh mb-1 font-medium">{inst.title}</h3>
            <div class="text-[0.78rem] text-accent tracking-wide mb-2.5">{inst.location}</div>
            <p class="text-[0.85rem] text-text-m leading-relaxed">{inst.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
